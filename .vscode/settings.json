{
    "files.autoSave": "afterDelay",
    "editor.formatOnSave": false,
    "[yaml]": {
        "editor.autoIndent": "full"
    },
    "[dockercompose]": {
        "editor.autoIndent": "full"
    },
    "search.exclude": {
        "**/src/data/database/**/*.json": true,
        "!**/src/data/database/master_db_metadata.json": false,
        "**/src/constants/fx/**/*.ndf": true,
        "**/tools/fxeditor/sample_source_vfx/**/*.ndf": true,
        "**/tools/fxeditor/sample_source_vfx/*.ndf": true,
    },
    "python.defaultInterpreterPath": "${workspaceFolder}/.venv/Scripts/python.exe",
}